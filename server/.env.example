PORT=4000
DATABASE_URL=postgres://localhost:5432/scheduler_dev
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=24h

# worker tuning
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL_MS=1000
HEARTBEAT_INTERVAL_MS=5000
WORKER_EXPIRY_MS=15000
SCHEDULER_TICK_MS=2000
SHUTDOWN_GRACE_MS=30000

# queue sharding: run worker groups that each claim a disjoint set of queues
# e.g. worker A: COUNT=2 INDEX=0, worker B: COUNT=2 INDEX=1
WORKER_SHARD_COUNT=1
WORKER_SHARD_INDEX=0

# optional: enables AI-generated failure summaries; Claude is preferred,
# Gemini is the fallback, and a heuristic summary is used when neither is set
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
